# fleet-memory relay deployment configuration
# Copy to .env.deploy and fill in actual values (chmod 600).
# .env.deploy is gitignored via the deploy/**/.env.deploy rule.

# --- Required (Settings.pg_dsn / embed_url have no defaults) ---
# Postgres+pgvector DSN. Password = deploy/nas/.env.deploy FLEET_MEMORY_PG_PASSWORD.
FLEET_MEMORY_PG_DSN=postgresql://fleet_memory:<DB_PASSWORD>@whitestocks.tailebf801.ts.net:5433/fleet_memory
# Embedding service base URL (nomic-embed-text-v1.5, 768 dims).
FLEET_MEMORY_EMBED_URL=http://promaxgb10-41b1:9000

# --- NATS (fleet-memory user; FEAT-MEM-04) ---
# Password = nats-infrastructure/.env FLEET_MEMORY_NATS_PASSWORD (the dedicated relay user).
FLEET_MEMORY_NATS_URL=nats://fleet-memory:<NATS_PASSWORD>@127.0.0.1:4222

# --- Optional overrides (defaults shown) ---
# FLEET_MEMORY_DLQ_SUBJECT=memory.dlq      # handler appends .{project_id}
# FLEET_MEMORY_MAX_DELIVER=5               # redelivery cap before parking
# FLEET_MEMORY_EMBED_MODEL=nomic-embed-text-v1.5
# FLEET_MEMORY_EMBED_DIMS=768
