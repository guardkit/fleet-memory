# Local disposable target — OPTIONAL overrides for the ephemeral compose.
#
# Unlike deploy/nas/.env.deploy, NO secrets are required here: the local
# docker-compose.yml hardcodes the non-secret dev credentials
# (fleet_memory / fleet_memory). Copy this to .env.deploy ONLY if you need to
# override the published port (e.g. to avoid clashing with another local Postgres).
#
#   cp .env.deploy.example .env.deploy
#
# The runbook's deploy/smoke steps source .env.deploy from this directory (cwd).

PGPORT=5432
# POSTGRES_PASSWORD=fleet_memory   # only if you also change it in docker-compose.yml
