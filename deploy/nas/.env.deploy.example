# NAS deployment configuration
# Copy to .env.deploy and fill in actual values (chmod 600)
# .env.deploy is gitignored via existing .env* rule

NAS_HOST=                          # e.g., synology.local or Tailscale name/IP
NAS_USER=                          # administrators-group user with key-auth only
NAS_SSH_PORT=                      # typically 22
NAS_DOCKER_ROOT=                   # e.g., /volume1/docker/fleet_memory
FLEET_MEMORY_PG_PASSWORD=          # generate: openssl rand -base64 24
